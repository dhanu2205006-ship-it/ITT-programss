#include <stdio.h>
#include <stdlib.h>
int main()
{
    int n;
    if (scanf("%d", &n) != 1) return 1;
       int* arr = (int*)malloc(n * sizeof(int));
    if (arr == NULL) return 1;
     for (int i = 0; i < n; i++) {
        if (scanf("%d", &arr[i]) != 1) {
            free(arr);
            return 1;
        }
    }
    for (int i = n - 1; i >= 0; i--) {
        printf("%d ", arr[i]);
    }
    free(arr);
    return 0;
}
