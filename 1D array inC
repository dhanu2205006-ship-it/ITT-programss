#include <stdio.h>
#include <stdlib.h>
int main() {
    int n, i, sum = 0;
    int *arr;
    // Read the size of the array
    if (scanf("%d", &n) != 1) return 1;
    arr = (int*)malloc(n * sizeof(int));    
    if (arr == NULL) {
        printf("Memory allocation failed\n");
        return 1;
    }
    for (i = 0; i < n; i++) {
        if (scanf("%d", &arr[i]) != 1) {
                       free(arr);
            return 1;
        }
        sum += arr[i];
    }
    printf("%d\n", sum);  
    free(arr);
    return 0;
}
