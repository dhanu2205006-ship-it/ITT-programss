#include <stdio.h>
#include <stdlib.h>
int main() {
    int n;
    scanf("%d", &n);
    int size = 2 * n - 1;
    for (int i = 0; i < size; i++) 
    {
        for (int j = 0; j < size; j++)
        {      
            int min_dist = i; // Distance to top
            if (j < min_dist) min_dist = j; // Distance to left
            if (size - 1 - i < min_dist) min_dist = size - 1 - i; // Distance to bottom
            if (size - 1 - j < min_dist) min_dist = size - 1 - j; // Distance to right         
            printf("%d ", n - min_dist);
        }
        printf("\n");
    }
    return 0;
}

