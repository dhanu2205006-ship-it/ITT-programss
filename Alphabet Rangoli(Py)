import string
def print_rangoli(size):
chars = string.ascii_lowercase
width = 4 * size - 3l
ines = []
for i in range(size):
left_side = chars[size-1 : i : -1]
right_side = chars[i : size]
row_content = "-".join(left_side + right_side)
lines.append(row_content.center(width, "-"))
result = "\n".join(lines[::-1] + lines[1:])
print(result)

